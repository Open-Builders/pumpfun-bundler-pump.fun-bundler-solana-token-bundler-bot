# =============================================================================
# Pump.fun_bundler_real — copy to .env and fill in values
# =============================================================================

# Cluster: mainnet | devnet (default: mainnet if unset)
# - mainnet: uses RPC_* + Jito or Lil-Jit (see LIL_JIT_MODE).
# - devnet: uses DEVNET_RPC_* only; txs send in order over RPC (no Jito).
CLUSTER=mainnet

# -----------------------------------------------------------------------------
# RPC — mainnet (required when CLUSTER=mainnet)
# -----------------------------------------------------------------------------
RPC_ENDPOINT=https://YOUR_MAINNET_RPC_URL/
RPC_WEBSOCKET_ENDPOINT=wss://YOUR_MAINNET_RPC_URL/

# -----------------------------------------------------------------------------
# RPC — devnet (required when CLUSTER=devnet; RPC_* above are not read)
# -----------------------------------------------------------------------------
DEVNET_RPC_ENDPOINT=https://api.devnet.solana.com
DEVNET_RPC_WEBSOCKET_ENDPOINT=wss://api.devnet.solana.com

# -----------------------------------------------------------------------------
# Lil-Jit (mainnet bundle path when LIL_JIT_MODE=true; ignored on devnet)
# -----------------------------------------------------------------------------
LIL_JIT_ENDPOINT=https://YOUR_MAINNET_RPC_URL/
LIL_JIT_WEBSOCKET_ENDPOINT=wss://YOUR_MAINNET_RPC_URL/
LIL_JIT_MODE=false

# -----------------------------------------------------------------------------
# Bundler amounts & Jito tip (Jito tip only applies on mainnet create tx)
# -----------------------------------------------------------------------------
SWAP_AMOUNT=0.01
DISTRIBUTION_WALLETNUM=4
JITO_FEE=0.001
MINIMUM_JITO_TIP=1000
SIMULATE_ONLY=false

# -----------------------------------------------------------------------------
# Token metadata (metadata image upload uses FILE path)
# -----------------------------------------------------------------------------
TOKEN_NAME=MyToken
TOKEN_SYMBOL=MTK
DESCRIPTION=Token description
TOKEN_SHOW_NAME=true
TOKEN_CREATE_ON=https://pump.fun
TWITTER=
TELEGRAM=
WEBSITE=
FILE=./image/your-image.jpg
VANITY_MODE=false

# -----------------------------------------------------------------------------
# Wallets (base58-encoded secret keys)
# -----------------------------------------------------------------------------
PRIVATE_KEY=YOUR_MAIN_WALLET_SECRET_BASE58
BUYER_WALLET=YOUR_BUYER_WALLET_SECRET_BASE58
BUYER_AMOUNT=0.01

# -----------------------------------------------------------------------------
# Optional — Fleek IPFS script (src/uploadToIpfs.ts) only
# -----------------------------------------------------------------------------
# PAT=
# PROJECT_ID=
